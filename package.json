{
  "name": "ripscloud",
  "description": "Rips Cloud — multi-tenant manager over the Colombian Ministry FEV RIPS / SISPRO upstream. Deployed on Cloudflare Workers + Pages.",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:ripscloud": "turbo dev --filter \"@ripscloud/ripscloud-*\"",
    "dev:ripscloud-api": "pnpm --filter @ripscloud/ripscloud-api run dev",
    "dev:ripscloud-web": "pnpm --filter @ripscloud/ripscloud-web run dev",
    "build": "turbo build",
    "build:ripscloud": "turbo build --filter \"@ripscloud/ripscloud-*\"",
    "build:packages": "pnpm -r --filter \"./packages/*\" run build",
    "lint": "turbo run lint",
    "test": "pnpm -r --parallel run test",
    "typecheck": "pnpm -r --parallel run lint",
    "db:migrate:ripscloud-api": "pnpm --filter @ripscloud/ripscloud-api run db:migrate",
    "db:migrate:ripscloud-api:remote": "pnpm --filter @ripscloud/ripscloud-api run db:migrate:remote",
    "setup:ripscloud": "pnpm db:migrate:ripscloud-api",
    "ship:ripscloud": "pnpm ship:ripscloud-api && pnpm ship:ripscloud-web",
    "ship:ripscloud-api": "pnpm --filter @ripscloud/ripscloud-api run ship",
    "ship:ripscloud-web": "pnpm --filter @ripscloud/ripscloud-web run ship",
    "clean": "find . -name 'node_modules' -prune -not -path './.git/*' | xargs rm -rf && find . -name 'dist' -prune -not -path './.git/*' -not -path './node_modules/*' | xargs rm -rf && find . -name '.turbo' -prune -not -path './.git/*' | xargs rm -rf && find . -name '.wrangler' -prune -not -path './.git/*' | xargs rm -rf",
    "nuke": "pnpm clean && rm -f pnpm-lock.yaml"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "devDependencies": {
    "turbo": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
