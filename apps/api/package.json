{
  "name": "@ripscloud/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "lint": "tsc -p tsconfig.json --noEmit",
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "ship": "wrangler deploy --env production",
    "cf-typegen": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply ripscloud-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ripscloud-db --remote"
  },
  "dependencies": {
    "@hono/swagger-ui": "catalog:",
    "@hono/zod-openapi": "catalog:",
    "@ripscloud/client": "workspace:*",
    "@ripscloud/commands": "workspace:*",
    "@ripscloud/db": "workspace:*",
    "@ripscloud/domain": "workspace:*",
    "@ripscloud/logger": "workspace:*",
    "@ripscloud/queries": "workspace:*",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
